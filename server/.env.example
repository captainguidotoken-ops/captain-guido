# Copy this file to .env and fill in your values.
# Never commit .env to git.

# GitHub fine-grained PAT — repo: captain-guido, Contents read+write
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# A long random string — acts as the shared secret between admin.html and this server
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVER_SECRET=change-me-to-something-random

# Anthropic API key (optional — only needed for the AI command chat)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Your Render/deployment URL (no trailing slash) — set this after you deploy
# e.g. https://cgt-admin.onrender.com
SERVER_URL=http://localhost:3000

# Port (Render sets this automatically, leave as-is)
PORT=3000
